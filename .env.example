# Set this only if your Compose runner starts from another working directory.
APP_DIR=/opt/szurubooru-tools

# Prebuilt image used by compose.yaml.
# Replace "your-github-user" with your GitHub username or organization.
IMAGE=ghcr.io/your-github-user/szurubooru-tools-web:latest

# Host port exposed by Docker and internal app port.
HOST_PORT=8080
APP_PORT=8080

# Optional: configure credentials through environment variables instead of the web UI.
# SZURU_BASE_URL=http://192.168.1.10:5200
# SZURU_USER=Importer
# SZURU_TOKEN=change-me
# E621_USER=change-me
# E621_API_KEY=change-me
# MAX_E621_PAGES=20
# E621_PAGE_DELAY_MS=1800
# E621_RETRY_COUNT=5
# E621_RETRY_BASE_MS=5000
# RULE34_USER_ID=change-me
# RULE34_API_KEY=change-me
